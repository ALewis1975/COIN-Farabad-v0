{
  "schema_version": "vCurrent",
  "description": "Static migration scenarios for ARC_pub_state payload contract.",
  "required_keys": [
    "insurgentPressure",
    "corruption",
    "infiltration",
    "civSentiment",
    "govLegitimacy",
    "civCasualties",
    "baseFuel",
    "baseAmmo",
    "baseMed",
    "intelCount",
    "opsCount",
    "incidentCount",
    "incidentHistoryTail",
    "metricsSnapshotsTail",
    "airbase"
